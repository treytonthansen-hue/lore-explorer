# Copy this file to `.env` in the project root and fill in your key.
# Get a key: https://aistudio.google.com/apikey
#
# Restart `npm run dev` after changing .env.
#
# Note: Vite exposes only variables prefixed with VITE_ to the browser bundle.
# For a public deployment, prefer a small backend proxy or serverless function
# so the key never ships to clients. For local capstone demos, restrict the key
# in Google AI Studio (e.g. HTTP referrer) and never commit `.env`.

# Preferred (standard Vite client env):
VITE_GEMINI_API_KEY=

# Also supported (wired in vite.config.js for people who skip the VITE_ prefix):
# GEMINI_API_KEY=

# Optional model override (either name works):
# VITE_GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-1.5-flash
